# Основные настройки
PROJECT_NAME=DIS
VERSION=1.0.0

# База данных
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/dis_db

# JWT
SECRET_KEY=your-secret-key-change-in-production-use-strong-random-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS: localhost и 127.0.0.1 для браузера — разные Origin; добавьте IP:8080 / :3000 при необходимости
# CORS_ORIGIN_REGEX=https://.*\.trycloudflare\.com
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001","http://localhost:8080","http://127.0.0.1:3000","http://127.0.0.1:8080"]

# Загрузка изображений (лого, фото товара): исходный файл до 12MB, на сервере → WebP ≤ 1MB
# MAX_UPLOAD_SIZE=12582912
# IMAGE_OUTPUT_MAX_BYTES=1048576
# IMAGE_OUTPUT_MAX_SIDE=1600

# Сборка Docker-фронта: URL API с точки зрения браузера.
# SAME_ORIGIN — запросы идут на /api/v1 того же хоста (прокси Next → backend).
# Для LAN без tunnel: http://192.168.x.x:8000
NEXT_PUBLIC_API_URL=SAME_ORIGIN

# --- Production (Yandex Cloud и т.п.) ---
# DATABASE_URL=postgresql://user:pass@host:6432/dis_db
# SECRET_KEY=<openssl rand -hex 32>
# CORS_ORIGINS=["https://ваш-frontend.containers.yandexcloud.net"]
# NEXT_PUBLIC_API_URL=SAME_ORIGIN или полный URL API для сборки фронта

# Email-уведомления о новых заказах (магазину)
# EMAIL_NOTIFICATIONS_ENABLED=true
# ORDER_NOTIFICATION_EMAIL=orders@your-shop.com
# SMTP_HOST=smtp.your-provider.com
# SMTP_PORT=587
# SMTP_USERNAME=mailer@your-shop.com
# SMTP_PASSWORD=your-smtp-password
# SMTP_USE_TLS=true
# SMTP_USE_SSL=false
# SMTP_FROM_EMAIL=mailer@your-shop.com
# SMTP_FROM_NAME=DIS

# Email-верификация регистрации (6-значный код)
# EMAIL_VERIFICATION_ENABLED=false
# EMAIL_VERIFICATION_CODE_TTL_MINUTES=10
# EMAIL_VERIFICATION_WINDOW_MINUTES=30
# EMAIL_VERIFICATION_RESEND_COOLDOWN_SECONDS=60
# AUTH_SEND_CODE_IP_LIMIT_PER_HOUR=20
# AUTH_SEND_CODE_EMAIL_LIMIT_PER_HOUR=5
# AUTH_REGISTER_IP_LIMIT_PER_HOUR=10
# AUTH_REGISTER_EMAIL_LIMIT_PER_HOUR=3
# PASSWORD_RESET_CODE_TTL_MINUTES=10
# PASSWORD_RESET_RESEND_COOLDOWN_SECONDS=60
# PASSWORD_RESET_IP_LIMIT_PER_HOUR=10
# PASSWORD_RESET_EMAIL_LIMIT_PER_HOUR=5
